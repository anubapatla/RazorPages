@page
@using static System.Collections.Specialized.BitVector32
@model Razorpages.Pages.Book.CreateModel
@{
    ViewData["Title"] = "CreateBook"; 
}
<div>
    <div class="card shadow mt-2">
        <div class="card-header">
            <h3>@ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="form-group">
                    <label asp-for="Books.BookTitle" class="control-label"></label>
                    <input asp-for="Books.BookTitle" class="form-control" />
                    <span asp-validation-for="Books.BookTitle" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Books.BookDescription" class="control-label"></label>
                    <input asp-for="Books.BookDescription" class="form-control" />
                    <span asp-validation-for="Books.BookDescription" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Books.Author" class="form-label"></label>
                    <input asp-for="Books.Author" class="form-control" />
                    <span asp-validation-for="Books.Author" class="text-danger"></span>
                </div>
                <div class="form-group mt-2">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
            </form>
            
        </div>
</div>
@section Scripts{
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}
